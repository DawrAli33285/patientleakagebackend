{
    "version":2,
    "builds":[
        {
            "src":"*.js",
            "use":"@vercel/node"
        }
    ],
    "functions": {
        "*.js": {
          "maxDuration": 900
        }
      },
    "routes":[
        {
            "src":"/(.*)",
            "dest":"/"
        }
    ]



    
}